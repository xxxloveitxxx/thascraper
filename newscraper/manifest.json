{
  "manifest_version": 3,
  "name": "ThaScraper",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://thascraper-mcp.onrender.com/*"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}