{
  "manifest_version": 3,
  "name": "ThaScraper",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "https://thascraper-mcp.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}